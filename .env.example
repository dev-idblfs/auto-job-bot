# ============================================================
# auto-job-bot – Environment Variables
# Copy this file to .env and fill in your values.
# For GitHub Actions / Cursor Cloud: add these as Secrets.
# ============================================================

# ── Email (REQUIRED) ─────────────────────────────────────────
# Gmail example: use a Google App Password, not your main password.
# Get one at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your.email@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=your.email@gmail.com

# Multiple recipients (comma-separated):
# EMAIL_RECIPIENT=you@gmail.com,friend@gmail.com

# Custom SMTP (optional – defaults to Gmail):
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# ── LinkedIn Posts scraper (OPTIONAL) ────────────────────────
# Only needed if linkedin_posts: true in config.yaml
LINKEDIN_EMAIL=your.linkedin@email.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Adzuna API (OPTIONAL – global job board) ─────────────────
# Free registration at: https://developer.adzuna.com/
# ADZUNA_APP_ID=your_app_id
# ADZUNA_API_KEY=your_api_key

# ── The Muse API (OPTIONAL) ──────────────────────────────────
# Free registration at: https://www.themuse.com/developers/api/v2
# THE_MUSE_API_KEY=your_api_key

# ── Debug ─────────────────────────────────────────────────────
# Set to any value to save an HTML preview file during --dry-run
# DRY_RUN_SAVE_HTML=1
